# ══════════════════════════════════════════════════════════════════════════════
#  Nova v2 — Environment Configuration
#  Copy to .env and fill in your values.
#  MOCK_MODE=true lets Nova run without any API keys.
# ══════════════════════════════════════════════════════════════════════════════

# ── Global ────────────────────────────────────────────────────────────────────
MOCK_MODE=true          # Set false to enable real hardware + API calls
NOVA_OWNER_NAME=User    # Your name (stored in memory as owner)

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── ElevenLabs TTS ───────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=...
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# ── Porcupine wake word ───────────────────────────────────────────────────────
PORCUPINE_ACCESS_KEY=...

# ── Speaker verification ─────────────────────────────────────────────────────
SPEAKER_THRESHOLD=0.65      # Cosine similarity threshold (0-1)

# ── FastAPI server ───────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# ── Safety ───────────────────────────────────────────────────────────────────
SAFETY_BLOCK_CRITICAL=true   # Hard-block CRITICAL risk actions
SAFETY_CONFIRM_HIGH=true     # Require confirmation for HIGH risk actions

# ── Google OAuth2 (Gmail + Calendar) ─────────────────────────────────────────
# Download from Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Place as: data/credentials/google_credentials.json
# Then run: python -m nova.setup.configure_google
# Token is saved automatically to: data/credentials/token.json
# (No env vars needed — credentials are stored as files, not env vars)
