# ══════════════════════════════════════════════════════════════════════════════
#  Nova v2 — Environment Configuration
#
#  Copy this file to .env and fill in your values.
#
#  MINIMUM SETUP (just one API key needed):
#    OPENAI_API_KEY=sk-...   ← required for the AI brain
#    Everything else uses free alternatives by default.
#
#  MOCK_MODE=true lets you run Nova without any API keys at all.
# ══════════════════════════════════════════════════════════════════════════════

# ── Global ────────────────────────────────────────────────────────────────────
MOCK_MODE=false          # true = no hardware/API calls (keyboard-only demo)
NOVA_OWNER_NAME=User     # Your name — stored in memory as owner

# ── OpenAI (required for the AI brain) ───────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Wake word ─────────────────────────────────────────────────────────────────
# "openwakeword"  FREE — offline, no API key, ships with built-in keywords
# "porcupine"     PAID — requires PORCUPINE_ACCESS_KEY below
WAKEWORD_ENGINE=openwakeword

# Built-in openwakeword models: hey_jarvis | alexa | hey_mycroft
# Train a custom "hey_nova" model: https://github.com/dscripka/openWakeWord
OPENWAKEWORD_MODEL=hey_jarvis

# [OPTIONAL] Porcupine — only needed when WAKEWORD_ENGINE=porcupine
# PORCUPINE_ACCESS_KEY=...

# ── TTS engine ────────────────────────────────────────────────────────────────
# "edge"       FREE — Microsoft Edge Neural TTS, no API key, internet required
# "openai"     PAID — OpenAI TTS-1 (uses OPENAI_API_KEY above)
# "elevenlabs" PAID — ElevenLabs ultra-realistic (requires key below)
# "pyttsx3"    FREE — fully offline Windows/Mac synthesis, no internet
TTS_ENGINE=edge
EDGE_TTS_VOICE=en-GB-SoniaNeural   # Natural British female voice
# Other great voices: en-US-JennyNeural, en-AU-NatashaNeural, en-IE-EmilyNeural

# [OPTIONAL] ElevenLabs — only used when TTS_ENGINE=elevenlabs or as fallback
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # Rachel (default)

# ── Speaker verification ─────────────────────────────────────────────────────
SPEAKER_THRESHOLD=0.65   # Cosine similarity (0–1); lower = more permissive

# ── Wake methods (both can be active simultaneously) ─────────────────────────
WAKE_METHODS=voice,clap  # voice | clap | voice,clap

# ── Clap detector tuning ─────────────────────────────────────────────────────
CLAP_ENABLED=true
CLAP_THRESHOLD=0.3       # RMS amplitude spike threshold (0–1)
CLAP_MIN_GAP=0.3         # Minimum seconds between two claps
CLAP_MAX_GAP=0.7         # Maximum seconds between two claps
CLAP_DEBOUNCE=2.0        # Seconds to ignore after successful detection

# ── FastAPI server ───────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_ENABLED=true

# ── Safety ───────────────────────────────────────────────────────────────────
SAFETY_BLOCK_CRITICAL=true   # Hard-block CRITICAL risk actions (rm -rf, etc.)
SAFETY_CONFIRM_HIGH=true     # Ask before HIGH risk actions (send email, etc.)

# ── Scheduled routines ────────────────────────────────────────────────────────
ROUTINE_ENABLED=true         # Enable morning briefing + end-of-day summaries

# ── TTS cache ────────────────────────────────────────────────────────────────
TTS_CACHE_ENABLED=true
TTS_CACHE_MAX_SIZE=100       # Max cached audio files (~50 MB)

# ── Proactive suggestions ────────────────────────────────────────────────────
PROACTIVE_SUGGESTIONS=true   # "Email sent. Want me to set a follow-up reminder?"

# ── Google OAuth2 (Gmail + Calendar — both optional) ─────────────────────────
# 1. Create a project at console.cloud.google.com
# 2. Enable Gmail API + Google Calendar API
# 3. Download OAuth2 credentials → save as data/credentials/google_credentials.json
# 4. Run: python -m nova.setup.configure_google
# Token is saved automatically to data/credentials/token.json
